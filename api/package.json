{
  "name": "tennis-workout-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Serverless API functions for Tennis Workout application",
  "scripts": {
    "build": "tsc && node build-post-process.js",
    "typecheck": "tsc --noEmit",
    "dev": "echo 'API functions served by Vercel dev from root'",
    "clean": "rimraf dist",
    "test": "node test-db.js",
    "setup": "node dev-setup.js",
    "query": "node db-query.js"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "@vercel/node": "^5.3.4"
  },
  "devDependencies": {
    "typescript": "~5.6.2",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "vercel": "^37.0.0"
  },
  "engines": {
    "node": ">=22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/tennis-workout.git",
    "directory": "api"
  },
  "keywords": [
    "vercel",
    "serverless",
    "api",
    "tennis",
    "workout",
    "postgres"
  ],
  "author": "Tennis Workout Team",
  "license": "MIT"
}
