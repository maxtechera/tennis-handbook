{
  "buildCommand": "pnpm build:turbo",
  "outputDirectory": "build",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/dist/analytics.js": {
      "runtime": "edge"
    },
    "api/dist/analytics-wizard.js": {
      "runtime": "edge"
    },
    "api/dist/track-stats.js": {
      "runtime": "edge"
    },
    "api/dist/wizard-start.js": {
      "runtime": "nodejs22.x",
      "memory": 512,
      "maxDuration": 15
    },
    "api/dist/wizard-save.js": {
      "runtime": "nodejs22.x", 
      "memory": 512,
      "maxDuration": 15
    },
    "api/dist/wizard-complete.js": {
      "runtime": "nodejs22.x",
      "memory": 512,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/dist/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
